# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
BKSouls/.utmp/
BKSouls/[Ll]ibrary/
BKSouls/[Tt]emp/
BKSouls/[Oo]bj/
BKSouls/[Bb]uild/
BKSouls/[Bb]uilds/
BKSouls/[Ll]ogs/
BKSouls/[Uu]ser[Ss]ettings/
BKSouls/*.log

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
BKSouls/[Mm]emoryCaptures/

# Recordings can get excessive in size
BKSouls/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
BKSouls/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
BKSouls/.vs/

# Gradle cache directory
BKSouls/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
BKSouls/ExportedObj/
BKSouls/.consulo/
BKSouls/*.csproj
BKSouls/*.unityproj
BKSouls/*.sln
BKSouls/*.suo
BKSouls/*.tmp
BKSouls/*.user
BKSouls/*.userprefs
BKSouls/*.pidb
BKSouls/*.booproj
BKSouls/*.svd
BKSouls/*.pdb
BKSouls/*.mdb
BKSouls/*.opendb
BKSouls/*.VC.db

# Unity3D generated meta files
BKSouls/*.pidb.meta
BKSouls/*.pdb.meta
BKSouls/*.mdb.meta

# Unity3D generated file on crash reports
BKSouls/sysinfo.txt

# Builds
BKSouls/*.apk
BKSouls/*.aab
BKSouls/*.unitypackage
BKSouls/*.unitypackage.meta
BKSouls/*.app

# Crashlytics generated file
BKSouls/crashlytics-build.properties

# Packed Addressables
BKSouls/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
BKSouls/[Aa]ssets/[Ss]treamingAssets/aa.meta
BKSouls/[Aa]ssets/[Ss]treamingAssets/aa/*

BKSouls/[Aa]ssets/ThirdParty/